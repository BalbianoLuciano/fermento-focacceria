rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Only the admins listed here can write. Firebase rules do not support
    // env vars, so the list is hardcoded. Mirror it with
    // NEXT_PUBLIC_ADMIN_EMAILS on the client.
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email in [
          'kowalczukannaiel@gmail.com',
          'balbiano06@gmail.com'
        ];
    }

    // Public read for products, reviews, gallery and settings. Writes are admin-only.
    match /products/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /reviews/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /gallery/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /ingredients/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders: anyone can create (public checkout from the web), but only admin
    // can read, update or delete. Shape is validated on the client and can be
    // reinforced with Cloud Functions if needed.
    match /orders/{id} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }
  }
}
